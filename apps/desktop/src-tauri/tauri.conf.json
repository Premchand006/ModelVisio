{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ModelVisio",
  "version": "0.0.0",
  "identifier": "com.modelvisio.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @modelvisio/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @modelvisio/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ModelVisio",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI-native neural-network model analyzer for edge deployment",
    "longDescription": "ModelVisio — Netron + TensorRT advisor + AI copilot in one tool."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Premchand006/ModelVisio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyMUNFNDA1QkNDOTM1NjMKUldSak5jbThCZVFja2xQVkhKLzlubTlVeitoMVkyVDEvTjkyakxpLzhXY1Q2T2IvSitSODBaQVUK"
    }
  }
}
