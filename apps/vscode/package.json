{
  "name": "modelvisio-vscode",
  "displayName": "ModelVisio",
  "description": "Open neural-network model files (ONNX, TFLite, PyTorch, …) as an interactive graph + inspector + compiler pre-flight.",
  "version": "0.0.0",
  "private": true,
  "publisher": "modelvisio",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Data Science", "Machine Learning"],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "modelvisio.modelViewer",
        "displayName": "ModelVisio",
        "selector": [
          { "filenamePattern": "*.onnx" },
          { "filenamePattern": "*.tflite" },
          { "filenamePattern": "*.pt" },
          { "filenamePattern": "*.pth" },
          { "filenamePattern": "*.mlmodel" },
          { "filenamePattern": "*.mlpackage" },
          { "filenamePattern": "*.gguf" },
          { "filenamePattern": "*.safetensors" }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "ModelVisio",
      "properties": {
        "modelvisio.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Google Gemini API key for the AI copilot. Get a free key at [aistudio.google.com/apikey](https://aistudio.google.com/apikey). Stored in your VS Code settings and used only by the extension host to call Google's API — never exposed to the webview."
        },
        "modelvisio.geminiModel": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "enum": ["gemini-2.5-flash", "gemini-2.5-flash-lite", "gemini-2.0-flash", "gemini-2.0-flash-lite"],
          "description": "Gemini model used by the AI copilot."
        },
        "modelvisio.webSearch": {
          "type": "boolean",
          "default": false,
          "description": "Enable Google Search grounding so the copilot can cite live links. Requires a paid-tier key — leave off for free keys."
        }
      }
    }
  },
  "scripts": {
    "build:webview": "vite build -c vite.webview.config.ts",
    "build:ext": "tsc -p tsconfig.ext.json",
    "build": "pnpm build:webview && pnpm build:ext",
    "typecheck": "tsc -p tsconfig.ext.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "package": "pnpm build && vsce package --no-dependencies --allow-missing-repository -o modelvisio.vsix"
  },
  "dependencies": {
    "@modelvisio/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
